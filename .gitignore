# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# drizzle
# Migrations are committed to git so the Docker build can use the
# exact SQL we ship (e.g. CREATE TABLE IF NOT EXISTS for idempotency
# against an already-initialized volume). Do NOT regenerate at build
# time — see Dockerfile.

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#docs
docs/
